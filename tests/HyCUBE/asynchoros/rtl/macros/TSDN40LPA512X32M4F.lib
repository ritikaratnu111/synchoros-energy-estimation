      pin (DA[3])  { capacitance : 0.004; } pin (DA[2])  { capacitance : 0.004; }
      pin (DA[1])  { capacitance : 0.004; } pin (DA[0])  { capacitance : 0.004; }
    }

    bus (BWEBA) { bus_type : bus32; direction : input;
      pin (BWEBA[31]) { capacitance : 0.004; } pin (BWEBA[30]) { capacitance : 0.004; }
      pin (BWEBA[29]) { capacitance : 0.004; } pin (BWEBA[28]) { capacitance : 0.004; }
      pin (BWEBA[27]) { capacitance : 0.004; } pin (BWEBA[26]) { capacitance : 0.004; }
