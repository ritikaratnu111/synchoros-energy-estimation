      pin (BWEBA[15]) { capacitance : 0.004; } pin (BWEBA[14]) { capacitance : 0.004; }
      pin (BWEBA[13]) { capacitance : 0.004; } pin (BWEBA[12]) { capacitance : 0.004; }
      pin (BWEBA[11]) { capacitance : 0.004; } pin (BWEBA[10]) { capacitance : 0.004; }
      pin (BWEBA[9])  { capacitance : 0.004; } pin (BWEBA[8])  { capacitance : 0.004; }
      pin (BWEBA[7])  { capacitance : 0.004; } pin (BWEBA[6])  { capacitance : 0.004; }
      pin (BWEBA[5])  { capacitance : 0.004; } pin (BWEBA[4])  { capacitance : 0.004; }
      pin (BWEBA[3])  { capacitance : 0.004; } pin (BWEBA[2])  { capacitance : 0.004; }
      pin (BWEBA[1])  { capacitance : 0.004; } pin (BWEBA[0])  { capacitance : 0.004; }
    }

    bus (AB) { bus_type : bus9; direction : input;
      pin (AB[8]) { capacitance : 0.004; } pin (AB[7]) { capacitance : 0.004; }
      pin (AB[6]) { capacitance : 0.004; } pin (AB[5]) { capacitance : 0.004; }
      pin (AB[4]) { capacitance : 0.004; } pin (AB[3]) { capacitance : 0.004; }
      pin (AB[2]) { capacitance : 0.004; } pin (AB[1]) { capacitance : 0.004; }
