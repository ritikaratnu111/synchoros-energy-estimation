library (tsdn40_dummy) {
  /* --- Units & basics --- */
  delay_model                 : table_lookup;
  time_unit                   : "1ns";
  voltage_unit                : "1V";
  current_unit                : "1mA";
  pulling_resistance_unit     : "1kohm";
  leakage_power_unit          : "1nW";
  capacitive_load_unit (1, pf);
  nom_process                 : 1;
  nom_voltage                 : 1.0;
  nom_temperature             : 25;

  /* Bus type helpers */
  type (bus9)  { base_type : array; data_type : bit; bit_width : 9;  bit_from : 8;  bit_to : 0;  downto : true; }
  type (bus32) { base_type : array; data_type : bit; bit_width : 32; bit_from : 31; bit_to : 0; downto : true; }

  cell (TSDN40LPA512X32M4F) {
    is_macro_cell            : true;
    area                     : 100000;

    /* Power pins (internal; not top-level ports) */
    pg_pin (VDD) { pg_type : primary_power;  voltage_name : "VDD"; }
    pg_pin (VSS) { pg_type : primary_ground; voltage_name : "VSS"; }

    /* --- Clock pins: mark as sinks so CTS can target them --- */
    pin (CLKA) { direction : input; clock : true; capacitance : 0.010; max_transition : 0.30; }
    pin (CLKB) { direction : input; clock : true; capacitance : 0.010; max_transition : 0.30; }
    pin (CLKM) { direction : input; clock : true; capacitance : 0.010; max_transition : 0.30; }

    /* --- Scalar control pins (assumed active-high) --- */
    pin (WEBA)  { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (CEBA)  { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (WEBB)  { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (CEBB)  { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (PD)    { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (WEBMA) { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (CEBMA) { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (WEBMB) { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (CEBMB) { direction : input; capacitance : 0.005; max_transition : 0.30; }
    pin (BIST)  { direction : input; capacitance : 0.005; max_transition : 0.30; }

    /* --- Buses --- */
    bus (AA) { bus_type : bus9; direction : input;
      pin (AA[8]) { capacitance : 0.004; } pin (AA[7]) { capacitance : 0.004; }
      pin (AA[6]) { capacitance : 0.004; } pin (AA[5]) { capacitance : 0.004; }
      pin (AA[4]) { capacitance : 0.004; } pin (AA[3]) { capacitance : 0.004; }
      pin (AA[2]) { capacitance : 0.004; } pin (AA[1]) { capacitance : 0.004; }
      pin (AA[0]) { capacitance : 0.004; }
    }

    bus (DA) { bus_type : bus32; direction : input;
      pin (DA[31]) { capacitance : 0.004; } pin (DA[30]) { capacitance : 0.004; }
      pin (DA[29]) { capacitance : 0.004; } pin (DA[28]) { capacitance : 0.004; }
      pin (DA[27]) { capacitance : 0.004; } pin (DA[26]) { capacitance : 0.004; }
      pin (DA[25]) { capacitance : 0.004; } pin (DA[24]) { capacitance : 0.004; }
      pin (DA[23]) { capacitance : 0.004; } pin (DA[22]) { capacitance : 0.004; }
      pin (DA[21]) { capacitance : 0.004; } pin (DA[20]) { capacitance : 0.004; }
      pin (DA[19]) { capacitance : 0.004; } pin (DA[18]) { capacitance : 0.004; }
      pin (DA[17]) { capacitance : 0.004; } pin (DA[16]) { capacitance : 0.004; }
