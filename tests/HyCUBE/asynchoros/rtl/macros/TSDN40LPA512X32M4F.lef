  PIN AA[7] DIRECTION INPUT ;  PORT LAYER M3 ; RECT 16 100 18 102 ; END  END AA[7]
  PIN AA[8] DIRECTION INPUT ;  PORT LAYER M3 ; RECT 18 100 20 102 ; END  END AA[8]

