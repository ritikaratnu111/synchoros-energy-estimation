VERSION 5.8 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO TSDN40LPA512X32M4F
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  SIZE 60.0 BY 100.0 ;        # TODO: pick conservative size (microns)
  SITE core ;                 # TODO: stdcell site name from your PDK
  SYMMETRY X Y ;

  # ------- Power/Ground pins (required) -------
  PIN VDD
    DIRECTION INOUT ; USE POWER ;
    PORT
      LAYER M5 ;               # TODO: PG routing layer
        RECT 0 99 60 100 ;
    END
  END VDD
  PIN VSS
    DIRECTION INOUT ; USE GROUND ;
    PORT
      LAYER M5 ;
        RECT 0 0 60 1 ;
    END
  END VSS

  # ------- Scalar control/clock pins (examples packed along the north edge) -------
  PIN CLKA  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT  5 100  7 102 ; END
  END CLKA
  PIN CLKB  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT  9 100 11 102 ; END
  END CLKB
  PIN CLKM  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 13 100 15 102 ; END
  END CLKM

  PIN CEBA  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 19 100 21 102 ; END
  END CEBA
  PIN CEBB  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 23 100 25 102 ; END
  END CEBB
  PIN CEBMA DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 27 100 29 102 ; END
  END CEBMA
  PIN CEBMB DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 31 100 33 102 ; END
  END CEBMB

  PIN WEBA  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 37 100 39 102 ; END
  END WEBA
  PIN WEBB  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 41 100 43 102 ; END
  END WEBB
