    PORT LAYER M3 ; RECT 45 100 47 102 ; END
  END WEBMA
  PIN WEBMB DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 49 100 51 102 ; END
  END WEBMB

  PIN PD    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 55 100 57 102 ; END
  END PD
  PIN BIST  DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER M3 ; RECT 59 100 61 102 ; END
  END BIST

  # Address A: AA[8:0]
  PIN AA[0] DIRECTION INPUT ;  PORT LAYER M3 ; RECT  2 100  4 102 ; END  END AA[0]
  PIN AA[1] DIRECTION INPUT ;  PORT LAYER M3 ; RECT  4 100  6 102 ; END  END AA[1]
