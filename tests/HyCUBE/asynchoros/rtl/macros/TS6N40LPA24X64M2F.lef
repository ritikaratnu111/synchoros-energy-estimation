VERSION 5.8 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO TS6N40LPA24X64M2F
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  SIZE 80.0 BY 80.0 ;
  SITE core ;
  SYMMETRY X Y ;

  # ===== Power / Ground =====
  PIN VDD
    DIRECTION INOUT ; USE POWER ;
    PORT
      LAYER M5 ;
        RECT 0.0 79.0 80.0 80.0 ;
    END
  END VDD

  PIN VSS
    DIRECTION INOUT ; USE GROUND ;
    PORT
      LAYER M5 ;
        RECT 0.0 0.0 80.0 1.0 ;
    END
  END VSS

  # ===== Scalars on SOUTH edge (x = 0..32 band) =====
  # order: WEB, CLKW, REB, CLKR, PD, WEBM, REBM, BIST  (step 1.0, width 0.5)
  PIN WEB   DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  0.00 0.00  0.50 0.50 ; END  END WEB
  PIN CLKW  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  1.00 0.00  1.50 0.50 ; END  END CLKW
  PIN REB   DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  2.00 0.00  2.50 0.50 ; END  END REB
  PIN CLKR  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  3.00 0.00  3.50 0.50 ; END  END CLKR
  PIN PD    DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  4.00 0.00  4.50 0.50 ; END  END PD
  PIN WEBM  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  5.00 0.00  5.50 0.50 ; END  END WEBM
  PIN REBM  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  6.00 0.00  6.50 0.50 ; END  END REBM
  PIN BIST  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  7.00 0.00  7.50 0.50 ; END  END BIST

  # ===== Address buses (SOUTH, still in x = 0..32 band), step 1.0, width 0.5 =====
  # AA[4:0]
  PIN AA[0] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  8.00 0.00  8.50 0.50 ; END  END AA[0]
  PIN AA[1] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT  9.00 0.00  9.50 0.50 ; END  END AA[1]
  PIN AA[2] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 10.00 0.00 10.50 0.50 ; END  END AA[2]
  PIN AA[3] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 11.00 0.00 11.50 0.50 ; END  END AA[3]
  PIN AA[4] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 12.00 0.00 12.50 0.50 ; END  END AA[4]

  # AB[4:0]
  PIN AB[0] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 13.00 0.00 13.50 0.50 ; END  END AB[0]
  PIN AB[1] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 14.00 0.00 14.50 0.50 ; END  END AB[1]
  PIN AB[2] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 15.00 0.00 15.50 0.50 ; END  END AB[2]
  PIN AB[3] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 16.00 0.00 16.50 0.50 ; END  END AB[3]
  PIN AB[4] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 17.00 0.00 17.50 0.50 ; END  END AB[4]

  # AMA[4:0]
  PIN AMA[0] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 18.00 0.00 18.50 0.50 ; END  END AMA[0]
  PIN AMA[1] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 19.00 0.00 19.50 0.50 ; END  END AMA[1]
  PIN AMA[2] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 20.00 0.00 20.50 0.50 ; END  END AMA[2]
  PIN AMA[3] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 21.00 0.00 21.50 0.50 ; END  END AMA[3]
  PIN AMA[4] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 22.00 0.00 22.50 0.50 ; END  END AMA[4]

  # AMB[4:0]
  PIN AMB[0] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 23.00 0.00 23.50 0.50 ; END  END AMB[0]
  PIN AMB[1] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 24.00 0.00 24.50 0.50 ; END  END AMB[1]
  PIN AMB[2] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 25.00 0.00 25.50 0.50 ; END  END AMB[2]
  PIN AMB[3] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 26.00 0.00 26.50 0.50 ; END  END AMB[3]
  PIN AMB[4] DIRECTION INPUT ; USE SIGNAL ; PORT LAYER M3 ; RECT 27.00 0.00 27.50 0.50 ; END  END AMB[4]

  # (leave x=27..32 empty as a spacer before Q bus)

  # ===== Q[63:0] on SOUTH edge (x = 32..80), step 0.625, width 0.5 =====
  # y = 0.0–0.5
  PIN Q[0]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 32.000 0.00 32.500 0.50 ; END  END Q[0]
  PIN Q[1]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 32.625 0.00 33.125 0.50 ; END  END Q[1]
  PIN Q[2]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 33.250 0.00 33.750 0.50 ; END  END Q[2]
  PIN Q[3]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 33.875 0.00 34.375 0.50 ; END  END Q[3]
  PIN Q[4]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 34.500 0.00 35.000 0.50 ; END  END Q[4]
  PIN Q[5]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 35.125 0.00 35.625 0.50 ; END  END Q[5]
  PIN Q[6]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 35.750 0.00 36.250 0.50 ; END  END Q[6]
  PIN Q[7]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 36.375 0.00 36.875 0.50 ; END  END Q[7]
  PIN Q[8]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 37.000 0.00 37.500 0.50 ; END  END Q[8]
  PIN Q[9]  DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 37.625 0.00 38.125 0.50 ; END  END Q[9]
  PIN Q[10] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 38.250 0.00 38.750 0.50 ; END  END Q[10]
  PIN Q[11] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 38.875 0.00 39.375 0.50 ; END  END Q[11]
  PIN Q[12] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 39.500 0.00 40.000 0.50 ; END  END Q[12]
  PIN Q[13] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 40.125 0.00 40.625 0.50 ; END  END Q[13]
  PIN Q[14] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 40.750 0.00 41.250 0.50 ; END  END Q[14]
  PIN Q[15] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 41.375 0.00 41.875 0.50 ; END  END Q[15]
  PIN Q[16] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 42.000 0.00 42.500 0.50 ; END  END Q[16]
  PIN Q[17] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 42.625 0.00 43.125 0.50 ; END  END Q[17]
  PIN Q[18] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 43.250 0.00 43.750 0.50 ; END  END Q[18]
  PIN Q[19] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 43.875 0.00 44.375 0.50 ; END  END Q[19]
  PIN Q[20] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 44.500 0.00 45.000 0.50 ; END  END Q[20]
  PIN Q[21] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 45.125 0.00 45.625 0.50 ; END  END Q[21]
  PIN Q[22] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 45.750 0.00 46.250 0.50 ; END  END Q[22]
  PIN Q[23] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 46.375 0.00 46.875 0.50 ; END  END Q[23]
  PIN Q[24] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 47.000 0.00 47.500 0.50 ; END  END Q[24]
  PIN Q[25] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 47.625 0.00 48.125 0.50 ; END  END Q[25]
  PIN Q[26] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 48.250 0.00 48.750 0.50 ; END  END Q[26]
  PIN Q[27] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 48.875 0.00 49.375 0.50 ; END  END Q[27]
  PIN Q[28] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 49.500 0.00 50.000 0.50 ; END  END Q[28]
  PIN Q[29] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 50.125 0.00 50.625 0.50 ; END  END Q[29]
  PIN Q[30] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 50.750 0.00 51.250 0.50 ; END  END Q[30]
  PIN Q[31] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 51.375 0.00 51.875 0.50 ; END  END Q[31]
  PIN Q[32] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 52.000 0.00 52.500 0.50 ; END  END Q[32]
  PIN Q[33] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 52.625 0.00 53.125 0.50 ; END  END Q[33]
  PIN Q[34] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 53.250 0.00 53.750 0.50 ; END  END Q[34]
  PIN Q[35] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 53.875 0.00 54.375 0.50 ; END  END Q[35]
  PIN Q[36] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 54.500 0.00 55.000 0.50 ; END  END Q[36]
  PIN Q[37] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 55.125 0.00 55.625 0.50 ; END  END Q[37]
  PIN Q[38] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 55.750 0.00 56.250 0.50 ; END  END Q[38]
  PIN Q[39] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 56.375 0.00 56.875 0.50 ; END  END Q[39]
  PIN Q[40] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 57.000 0.00 57.500 0.50 ; END  END Q[40]
  PIN Q[41] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 57.625 0.00 58.125 0.50 ; END  END Q[41]
  PIN Q[42] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 58.250 0.00 58.750 0.50 ; END  END Q[42]
  PIN Q[43] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 58.875 0.00 59.375 0.50 ; END  END Q[43]
  PIN Q[44] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 59.500 0.00 60.000 0.50 ; END  END Q[44]
  PIN Q[45] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 60.125 0.00 60.625 0.50 ; END  END Q[45]
  PIN Q[46] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 60.750 0.00 61.250 0.50 ; END  END Q[46]
  PIN Q[47] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 61.375 0.00 61.875 0.50 ; END  END Q[47]
  PIN Q[48] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 62.000 0.00 62.500 0.50 ; END  END Q[48]
  PIN Q[49] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 62.625 0.00 63.125 0.50 ; END  END Q[49]
  PIN Q[50] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 63.250 0.00 63.750 0.50 ; END  END Q[50]
  PIN Q[51] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 63.875 0.00 64.375 0.50 ; END  END Q[51]
  PIN Q[52] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 64.500 0.00 65.000 0.50 ; END  END Q[52]
  PIN Q[53] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 65.125 0.00 65.625 0.50 ; END  END Q[53]
  PIN Q[54] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 65.750 0.00 66.250 0.50 ; END  END Q[54]
  PIN Q[55] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 66.375 0.00 66.875 0.50 ; END  END Q[55]
  PIN Q[56] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 67.000 0.00 67.500 0.50 ; END  END Q[56]
  PIN Q[57] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 67.625 0.00 68.125 0.50 ; END  END Q[57]
  PIN Q[58] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 68.250 0.00 68.750 0.50 ; END  END Q[58]
  PIN Q[59] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 68.875 0.00 69.375 0.50 ; END  END Q[59]
  PIN Q[60] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 69.500 0.00 70.000 0.50 ; END  END Q[60]
  PIN Q[61] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 70.125 0.00 70.625 0.50 ; END  END Q[61]
  PIN Q[62] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 70.750 0.00 71.250 0.50 ; END  END Q[62]
  PIN Q[63] DIRECTION OUTPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 71.375 0.00 71.875 0.50 ; END  END Q[63]

  # ===== D[63:0] on WEST edge (x=0.0–0.5), step 1.0 in Y, top-down from 79 =====
  PIN D[0]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 79.00 0.50 80.00 ; END  END D[0]
  PIN D[1]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 78.00 0.50 79.00 ; END  END D[1]
  PIN D[2]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 77.00 0.50 78.00 ; END  END D[2]
  PIN D[3]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 76.00 0.50 77.00 ; END  END D[3]
  PIN D[4]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 75.00 0.50 76.00 ; END  END D[4]
  PIN D[5]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 74.00 0.50 75.00 ; END  END D[5]
  PIN D[6]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 73.00 0.50 74.00 ; END  END D[6]
  PIN D[7]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 72.00 0.50 73.00 ; END  END D[7]
  PIN D[8]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 71.00 0.50 72.00 ; END  END D[8]
  PIN D[9]  DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 70.00 0.50 71.00 ; END  END D[9]
  PIN D[10] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 69.00 0.50 70.00 ; END  END D[10]
  PIN D[11] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 68.00 0.50 69.00 ; END  END D[11]
  PIN D[12] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 67.00 0.50 68.00 ; END  END D[12]
  PIN D[13] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 66.00 0.50 67.00 ; END  END D[13]
  PIN D[14] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 65.00 0.50 66.00 ; END  END D[14]
  PIN D[15] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 64.00 0.50 65.00 ; END  END D[15]
  PIN D[16] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 63.00 0.50 64.00 ; END  END D[16]
  PIN D[17] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 62.00 0.50 63.00 ; END  END D[17]
  PIN D[18] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 61.00 0.50 62.00 ; END  END D[18]
  PIN D[19] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 60.00 0.50 61.00 ; END  END D[19]
  PIN D[20] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 59.00 0.50 60.00 ; END  END D[20]
  PIN D[21] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 58.00 0.50 59.00 ; END  END D[21]
  PIN D[22] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 57.00 0.50 58.00 ; END  END D[22]
  PIN D[23] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 56.00 0.50 57.00 ; END  END D[23]
  PIN D[24] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 55.00 0.50 56.00 ; END  END D[24]
  PIN D[25] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 54.00 0.50 55.00 ; END  END D[25]
  PIN D[26] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 53.00 0.50 54.00 ; END  END D[26]
  PIN D[27] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 52.00 0.50 53.00 ; END  END D[27]
  PIN D[28] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 51.00 0.50 52.00 ; END  END D[28]
  PIN D[29] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 50.00 0.50 51.00 ; END  END D[29]
  PIN D[30] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 49.00 0.50 50.00 ; END  END D[30]
  PIN D[31] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 48.00 0.50 49.00 ; END  END D[31]
