  PIN D[60] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 19.00 0.50 20.00 ; END  END D[60]
  PIN D[61] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 18.00 0.50 19.00 ; END  END D[61]
  PIN D[62] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 17.00 0.50 18.00 ; END  END D[62]
  PIN D[63] DIRECTION INPUT ; USE SIGNAL ;  PORT LAYER M3 ; RECT 0.00 16.00 0.50 17.00 ; END  END D[63]

  # ===== DM[63:0] on EAST edge (x=79.5–80.0), step 1.0 in Y, top-down from 79 =====
